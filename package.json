  },
  "homepage": "https://github.com/kaspernj/uniqunize#readme",
  "devDependencies": {
    "eslint": "^10.0.2",
    "eslint-plugin-jsdoc": "^63.0.0",
    "jasmine": "^6.0.0",
    "release-patch": "^1.0.0",
    "typescript": "^6.0.2"
  },
  "description": "Return unique items from an array, with optional projection for comparisons."
